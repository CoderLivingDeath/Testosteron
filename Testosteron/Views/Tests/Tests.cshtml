@using Testosteron.Controllers
@model PaginatedTestCards

<div class="container px-4 py-4">
    <div class="row g-4">
        <!-- Карточки тестов -->
        @foreach (var test in Model)
        {
            <div class="col-lg-4 col-md-6">
                <partial name="TestCardPartial" model="test"></partial>
            </div>
        }
    </div>

    <!-- Пагинация -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Навигация по тестам" class="mt-5">
            <ul class="pagination justify-content-center">
                <!-- Первая -->
                <li class="page-item @(Model.IsFirstPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="1">
                        <i class="bi bi-chevron-double-left"></i> Первая
                    </a>
                </li>

                <!-- Предыдущая -->
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                <!-- Номера страниц (текущие ±2) -->
                @{
                    var startPage = Math.Max(1, Model.PageIndex - 2);
                    var endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                <!-- Следующая -->
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>

                <!-- Последняя -->
                <li class="page-item @(Model.IsLastPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages">
                        Последняя <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>
