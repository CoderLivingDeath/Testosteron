@using Testosteron.Controllers
@model PaginatedTestCards

<style>
    .pagination .page-item:first-child .page-link,
    .pagination .page-item:last-child .page-link {
        margin-left: 0;
        border-radius: var(--bs-pagination-border-radius);
    }
    .pagination .page-link {
        padding: var(--bs-pagination-padding-y) var(--bs-pagination-padding-x);
    }
    .test-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
</style>

<div class="container px-4 py-4" style="min-height: calc(100vh - 80px); display: flex; flex-direction: column;">
    <div class="test-cards-grid">
        @foreach (var test in Model)
        {
            <partial name="TestCardPartial" model="test"></partial>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Навигация по тестам" class="mt-auto mb-4 pt-4">
            <ul class="pagination justify-content-center mb-0">
                <!-- Первая -->
                <li class="page-item @(Model.IsFirstPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="1">
                        <i class="bi bi-chevron-double-left"></i> Первая
                    </a>
                </li>

                <!-- Предыдущая -->
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                <!-- Номера страниц (текущие ±2) -->
                @{
                    var startPage = Math.Max(1, Model.PageIndex - 2);
                    var endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                <!-- Следующая -->
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>

                <!-- Последняя -->
                <li class="page-item @(Model.IsLastPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages">
                        Последняя <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>
