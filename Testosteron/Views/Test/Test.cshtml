@model TestViewModel
@{
    ViewBag.Title = Model.TestTitle;
}

<form id="form" action="/Test" method="post" class="test container mt-4">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="TestId" />

    <h1 class="mb-4">@Model.TestTitle</h1>

    @if (!string.IsNullOrEmpty(Model.TestDescription))
    {
        <div class="mb-4">
            <h6>@Model.TestDescription</h6>
        </div>
    }

    @for (int i = 0; i < Model.TestFields.Count(); i++)
    {
        @await Component.InvokeAsync("PublicTestField", new { prefix = $"{nameof(Model.TestFields)}[{i}]", field = Model.TestFields.ElementAt(i) })
    }

    <div class="mt-4">
        <div id="alertPlaceholder"></div>
        <button type="submit" class="btn btn-primary btn-lg">Отправить</button>
    </div>
</form>

@section Scripts
{
    <script>
        function showAlert(type, message) {
            const alertHtml =
                `<div class="alert alert-${type} alert-dismissible fade show mt-3" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>`;
            document.getElementById('alertPlaceholder').innerHTML = alertHtml;
        }

        function clearFieldErrors() {
            document.querySelectorAll('.field-card').forEach(card => {
                const errorDiv = card.querySelector('.field-validation-error');
                if (errorDiv) {
                    errorDiv.style.display = 'none';
                    errorDiv.textContent = '';
                }
                card.classList.remove('border-danger');
            });
        }

        function validateField(card) {
            const isRequired = card.dataset.required === 'true';
            const fieldType = card.querySelector('input[name*="TestFieldType"]')?.value;
            const errorDiv = card.querySelector('.field-validation-error');
            
            if (!isRequired) {
                return true;
            }

            let isValid = false;
            const inputs = card.querySelectorAll('.field-input');

            if (fieldType === 'check') {
                isValid = Array.from(inputs).some(input => input.checked);
            } else if (fieldType === 'radio') {
                isValid = Array.from(inputs).some(input => input.checked);
            } else {
                isValid = Array.from(inputs).some(input => input.value.trim() !== '');
            }

            if (!isValid && errorDiv) {
                errorDiv.textContent = 'Пожалуйста, ответьте на этот вопрос';
                errorDiv.style.display = 'block';
                card.classList.add('border-danger');
            }

            return isValid;
        }

        function validateAllFields() {
            let isValid = true;
            document.querySelectorAll('.field-card').forEach(card => {
                if (!validateField(card)) {
                    isValid = false;
                }
            });
            return isValid;
        }

        document.querySelectorAll('.field-input').forEach(input => {
            input.addEventListener('change', function() {
                const card = this.closest('.field-card');
                if (card) {
                    validateField(card);
                }
            });
        });

        $("#form").submit(function(e) {
            e.preventDefault();
            clearFieldErrors();
            
            if (!validateAllFields()) {
                showAlert('danger', 'Пожалуйста, заполните все обязательные поля');
                return;
            }

            const formData = new FormData(this);
            fetch("test", {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    return response.text().then(text => {
                        throw new Error(text || "HTTP " + response.status + ": " + response.statusText);
                    });
                }
                return response.text().then(text => {
                    try {
                        return JSON.parse(text);
                    } catch {
                        return text;
                    }
                });
            })
            .then(result => {
                if(result.success)
                {
                    showAlert('success', result.message);
                }
                else
                {
                    showAlert('danger', result.message);
                }
            })
            .catch(error => {
                showAlert('danger', error.message);
            });
        });
    </script>
}