@{
    ViewData["Title"] = "Главная страница";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Testosteron</h1>
        <p class="lead text-muted">Система онлайн-тестирования</p>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="h4 mb-4">О системе</h2>
                    <p class="mb-3">
                        <strong>Testosteron</strong> — это современная веб-система для создания и прохождения онлайн-тестов.
                        Платформа предназначена для образовательных учреждений, HR-отделов и компаний, которым необходимо
                        проводить тестирование знаний сотрудников или кандидатов.
                    </p>
                    <p class="mb-3">
                        Создавайте тесты с различными типами вопросов: текстовые ответы, выбор одного варианта
                        или множественный выбор. Проходите тесты без регистрации или сохраняйте свои результаты
                        в личном кабинете.
                    </p>
                    <div class="d-flex gap-3 mt-4">
                        <a href="/Tests" class="btn btn-primary btn-lg">
                            Перейти к тестам
                        </a>
                        <a href="/Account/Register" class="btn btn-outline-secondary btn-lg">
                            Регистрация
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-journal-text text-primary" viewBox="0 0 16 16">
                            <path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                            <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1h1v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v1H1V2a2 2 0 0 1 2-2z"/>
                            <path d="M1 5v-.5a.5.5 0 0 1 1 0V5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1zm0 3v-.5a.5.5 0 0 1 1 0V8h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1zm0 3v-.5a.5.5 0 0 1 1 0v.5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1z"/>
                        </svg>
                    </div>
                    <h3 class="h5">Создание тестов</h3>
                    <p class="text-muted">Создавайте тесты с гибкой структурой и различными типами вопросов</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-pencil-square text-success" viewBox="0 0 16 16">
                            <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                            <path d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z"/>
                        </svg>
                    </div>
                    <h3 class="h5">Прохождение тестов</h3>
                    <p class="text-muted">Проходите тесты онлайн без регистрации или сохраняйте результаты</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-bar-chart-line text-info" viewBox="0 0 16 16">
                            <path d="M11 2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7h1V7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7h2V2zm1 12h2V1H7v12zm-3 0h1V3H5v10zm1 0h2V3H6v10z"/>
                        </svg>
                    </div>
                    <h3 class="h5">Результаты</h3>
                    <p class="text-muted">Просматривайте историю прохождений и анализируйте прогресс</p>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center">
        <a href="/Tests" class="btn btn-primary btn-lg px-5">
            Посмотреть доступные тесты
        </a>
    </div>
</div>
