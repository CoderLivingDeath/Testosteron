@model Testosteron.Models.TestCardModel

<a href="/test?guid=@Model.Id" class="card border-0 text-decoration-none stretched-link"
   style="box-shadow: 0 0.25rem 0.75rem rgba(0, 0, 0, 0.15);
          transition: all 0.2s ease;
          display: block;
          color: inherit;
          height: 100%;
          min-height: 200px;"
   title="@Model.Title">
    <div class="card-body p-4">
        <h5 class="card-title fw-semibold mb-2 text-truncate"
            style="max-height: 2.4em; line-height: 1.2em; transition: color 0.2s ease; cursor: default;"
            title="@Model.Title">
            @Model.Title
        </h5>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="card-text text-muted small mb-0 lh-sm"
               style="max-height: 3.6em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; cursor: default;">
                @Model.Description
            </p>
        }
        else
        {
            <p class="card-text text-muted small mb-0" style="opacity: 0.5; cursor: default;">Без описания</p>
        }
    </div>
</a>

<style>
    .card:hover {
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.25) !important;
        transform: translateY(-4px);
    }

        .card:hover .card-title {
            color: #0d6efd !important;
        }
</style>
